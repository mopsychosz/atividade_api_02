{
	"info": {
		"name": "Filmes API CRUD",
		"description": "Testes completos de CRUD e Validação",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. GET Todos os Filmes",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
							"pm.test(\"Response is array\", function () { var jsonData = pm.response.json(); pm.expect(jsonData).to.be.an('array'); pm.expect(jsonData.length).to.be.at.least(10); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": { "raw": "http://localhost:3000/api/filmes", "protocol": "http", "host": [ "localhost" ], "port": "3000", "path": [ "api", "filmes" ] }
			}
		},
		{
			"name": "2. POST Criar Filme",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 201\", function () { pm.response.to.have.status(201); });",
							"var jsonData = pm.response.json();",
							"pm.environment.set(\"movieId\", jsonData.id);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [ { "key": "Content-Type", "value": "application/json" } ],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"title\": \"Gladiador\",\n  \"director\": \"Ridley Scott\",\n  \"year\": 2000,\n  \"genre\": \"Ação\"\n}"
				},
				"url": { "raw": "http://localhost:3000/api/filmes", "protocol": "http", "host": [ "localhost" ], "port": "3000", "path": [ "api", "filmes" ] }
			}
		},
		{
			"name": "3. POST Validar Erro (Ano Inválido)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 400\", function () { pm.response.to.have.status(400); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [ { "key": "Content-Type", "value": "application/json" } ],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"title\": \"Filme do Futuro\",\n  \"director\": \"Alguém\",\n  \"year\": \"dois mil\",\n  \"genre\": \"Ação\"\n}"
				},
				"url": { "raw": "http://localhost:3000/api/filmes", "protocol": "http", "host": [ "localhost" ], "port": "3000", "path": [ "api", "filmes" ] }
			}
		},
		{
			"name": "4. GET Filme por ID",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": { "raw": "http://localhost:3000/api/filmes/{{movieId}}", "protocol": "http", "host": [ "localhost" ], "port": "3000", "path": [ "api", "filmes", "{{movieId}}" ] }
			}
		},
		{
			"name": "5. PUT Atualizar Filme",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
							"pm.test(\"Title is updated\", function () { var jsonData = pm.response.json(); pm.expect(jsonData.title).to.eql(\"Gladiador (Versão Estendida)\"); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PUT",
				"header": [ { "key": "Content-Type", "value": "application/json" } ],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"title\": \"Gladiador (Versão Estendida)\",\n  \"director\": \"Ridley Scott\",\n  \"year\": 2000,\n  \"genre\": \"Épico\"\n}"
				},
				"url": { "raw": "http://localhost:3000/api/filmes/{{movieId}}", "protocol": "http", "host": [ "localhost" ], "port": "3000", "path": [ "api", "filmes", "{{movieId}}" ] }
			}
		},
		{
			"name": "6. DELETE Filme",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 204\", function () { pm.response.to.have.status(204); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "DELETE",
				"header": [],
				"url": { "raw": "http://localhost:3000/api/filmes/{{movieId}}", "protocol": "http", "host": [ "localhost" ], "port": "3000", "path": [ "api", "filmes", "{{movieId}}" ] }
			}
		},
		{
			"name": "7. GET Validar 404",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 404\", function () { pm.response.to.have.status(404); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": { "raw": "http://localhost:3000/api/filmes/{{movieId}}", "protocol": "http", "host": [ "localhost" ], "port": "3000", "path": [ "api", "filmes", "{{movieId}}" ] }
			}
		}
	]
}
